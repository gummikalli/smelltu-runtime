# Copy to .env and fill in the three required values. Never commit .env.

# 1) Your personal runtime token — log in at https://courses.smelltuher.is,
#    open "local runtime", click "generate runtime token", paste it here.
RUNTIME_TOKEN=

# 2) Password for your LOCAL login at http://localhost:3000 (min 12 chars).
#    This account exists only on your machine.
LOCAL_USER_PASSWORD=

# 3) Local database password — any random string, used only inside Docker.
POSTGRES_PASSWORD=

# How Claude Code in your sandbox talks to the AI (the installer asks you):
#   classroom    = shared instructor access via your runtime token (default)
#   subscription = your own Claude account — type `claude` and log in once
#   apikey       = your own key below (pay-as-you-go)
#AI_MODE=classroom
#ANTHROPIC_API_KEY=

# Optional: use different host ports if 3000/3001/8080 are taken on your machine.
#APP_PORT=3000
#SYNC_PORT=3001
#PREVIEW_PORT=8080

# Optional overrides (sensible defaults):
#ANTHROPIC_MODEL=claude-sonnet-5
#LOCAL_USER_EMAIL=student@localhost.local
#LOCAL_USER_NAME=Student
#COURSE_SLUG=vibe-coding
#CLOUD_API_URL=https://courses.smelltuher.is
#CLOUD_SYNC_URL=wss://courses.smelltuher.is/sync
